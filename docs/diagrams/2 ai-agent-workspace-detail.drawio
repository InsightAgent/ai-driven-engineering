        <mxCell id="9" value="&lt;b&gt;Human-in-Loop Gates&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef2f2;strokeColor=#e11d48;strokeWidth=1;fontSize=10;fontFamily=Inter;arcSize=8;" parent="1" vertex="1">
          <mxGeometry x="960" y="135" width="120" height="35" as="geometry" />
        </mxCell>
        <mxCell id="10" value="&lt;b&gt;AI Agents — Roles &amp;amp; Responsibilities&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9fafb;strokeColor=#6b7280;strokeWidth=2;verticalAlign=top;fontStyle=1;fontSize=13;fontFamily=Inter;arcSize=10;" parent="1" vertex="1">
          <mxGeometry x="20" y="220" width="1160" height="370" as="geometry" />
        </mxCell>
        <mxCell id="11" value="&lt;b&gt;Business Analyst Agent&lt;/b&gt;&lt;br/&gt;&lt;span style=&#x27;font-size:9px;color:#666&#x27;&gt;Responsibilities: Elicit/refine requirements, write acceptance criteria (Gherkin), define data requirements &amp;amp; business rules, map data flow &amp;amp; transformation logic&lt;br/&gt;Tools: VS Code, Markdown, BDD&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6b7280;strokeWidth=1;fontSize=10;fontFamily=Inter;arcSize=8;shadow=1;" parent="1" vertex="1">
          <mxGeometry x="40" y="250" width="1120" height="55" as="geometry" />
        </mxCell>
        <mxCell id="12" value="&lt;b&gt;Architect Agent&lt;/b&gt;&lt;br/&gt;&lt;span style=&#x27;font-size:9px;color:#666&#x27;&gt;Responsibilities: Design system architecture, select tech stack &amp;amp; patterns, define data contracts &amp;amp; schemas, ensure scalability &amp;amp; compliance&lt;br/&gt;Tools: Draw.io, ADRs, C4 model&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6b7280;strokeWidth=1;fontSize=10;fontFamily=Inter;arcSize=8;shadow=1;" parent="1" vertex="1">
          <mxGeometry x="40" y="315" width="1120" height="55" as="geometry" />
        </mxCell>
        <mxCell id="13" value="&lt;b&gt;Scrum Master Agent&lt;/b&gt;&lt;br/&gt;&lt;span style=&#x27;font-size:9px;color:#666&#x27;&gt;Responsibilities: Break work into sprint tasks, track progress &amp;amp; dependencies, sync with DevOps/JIRA boards, manage capacity &amp;amp; velocity&lt;br/&gt;Tools: JIRA API, Sprint metrics&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6b7280;strokeWidth=1;fontSize=10;fontFamily=Inter;arcSize=8;shadow=1;" parent="1" vertex="1">
          <mxGeometry x="40" y="380" width="1120" height="55" as="geometry" />
        </mxCell>
        <mxCell id="14" value="&lt;b&gt;Data Engineer Agent&lt;/b&gt;&lt;br/&gt;&lt;span style=&#x27;font-size:9px;color:#666&#x27;&gt;Responsibilities: Build &amp;amp; optimise data pipelines, implement data quality checks, manage data catalog &amp;amp; lineage, deploy infra with IaC (Terraform)&lt;br/&gt;Tools: dbt, Airflow, Spark, SQL&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#6b7280;strokeWidth=1;fontSize=10;fontFamily=Inter;arcSize=8;shadow=1;" parent="1" vertex="1">
          <mxGeometry x="40" y="445" width="1120" height="55" as="geometry" />
        </mxCell>
        <mxCell id="15" value="&lt;b&gt;QA Engineer Agent&lt;/b&gt;&lt;br/&gt;&lt;span style=&#x27;font-size:9px;color:#666&#x27;&gt;Responsibilities: Validate data quality &amp;amp; accuracy, run Great Expectations tests, verify acceptance criteria, generate test reports &amp;amp; dashboards&lt;br/&gt;Tools: GX, Soda, pytest, CI&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#6b7280;strokeWidth=1;fontSize=10;fontFamily=Inter;arcSize=8;shadow=1;" parent="1" vertex="1">
